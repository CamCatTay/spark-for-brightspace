{
  "manifest_version": 3,
  "name": "Spark - for Brightspace",
  "version": "1.0.1",
  "description": "A productivity extension for Brightspace.",
  "icons": {
    "16": "/icons/spark_logo.png",
    "48": "/icons/spark_logo.png",
    "128": "/icons/spark_logo.png"
  },
  "background": {
    "service_worker": "/src/background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/d2l/*"],
      "all_frames": false,
      "js": [
        "/src/utils/date-utils.js",
        "/src/utils/color-utils.js",
        "/src/ui/panel.js",
        "/src/ui/components.js",
        "/src/content.js"
      ],
      "css": ["/styles/sidepanel.css"]
    }
  ],
  "action": {
    "default_icon": "/icons/spark_logo.png",
    "default_title": "Spark - for Brightspace"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}