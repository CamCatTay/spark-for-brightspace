{
  "manifest_version": 3,
  "name": "D2L-todolist",
  "version": "1.0.0",
  "description": "An extension to manage a to-do list for D2L courses.",
  "content_scripts": [
    {
      "matches": ["https://*/d2l/*"],
      "all_frames": false,
      "js": ["/scripts/content.js"]
    }
  ],
  "action": {
    "default_popup": "/html/popup.html",
    "default_icon": "/images/notebook.png"
  }
}