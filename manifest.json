{
  "manifest_version": 3,
  "name": "Spark - for Brightspace",
  "version": "1.0.0",
  "description": "A productivity extension for Brightspace.",
  "icons": {
    "16": "/images/spark_logo.png",
    "48": "/images/spark_logo.png",
    "128": "/images/spark_logo.png"
  },
  "background": {
    "service_worker": "/scripts/background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/d2l/*"],
      "all_frames": false,
      "js": [
        "/scripts/date-utils.js",
        "/scripts/color-utils.js",
        "/scripts/panel.js",
        "/scripts/ui-components.js",
        "/scripts/content.js"
      ],
      "css": ["/styles/sidepanel.css"]
    }
  ],
  "action": {
    "default_icon": "/images/spark_logo.png",
    "default_title": "Spark for Brightspace"
  },
  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"]
    }
  ]
}