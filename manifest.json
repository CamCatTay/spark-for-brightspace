{
  "manifest_version": 3,
  "name": "D2L To-Do List",
  "version": "1.0.0",
  "description": "An extension to manage a to-do list for D2L courses.",
  "background": {
    "service_worker": "/scripts/background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/d2l/*"],
      "all_frames": false,
      "js": [
        "/scripts/date-utils.js",
        "/scripts/color-utils.js",
        "/scripts/panel.js",
        "/scripts/ui-components.js",
        "/scripts/content.js"
      ],
      "css": ["/styles/sidepanel.css"]
    }
  ],
  "action": {
    "default_icon": "/images/notebook.png",
    "default_title": "D2L To-Do List"
  }
}