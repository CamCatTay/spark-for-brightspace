{
  "manifest_version": 3,
  "name": "D2L To-Do List",
  "version": "1.0.0",
  "description": "An extension to manage a to-do list for D2L courses.",
  "background": {
    "service_worker": "/scripts/background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/d2l/*"],
      "all_frames": false,
      "js": ["/scripts/content.js"]
    }
  ],
  "action": {
    "default_popup": "/html/popup.html",
    "default_icon": "/images/notebook.png"
  },
  "side_panel": {
    "default_path": "/html/sidepanel.html"
  }
}