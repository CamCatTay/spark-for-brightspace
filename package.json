{
  "name": "spark-for-brightspace",
  "version": "1.2.1",
  "description": "A productivity extension for Brightspace.",
  "scripts": {
    "test": "vitest run",
    "build:content": "vite build --config vite.content.config.js",
    "build:background": "vite build --config vite.background.config.js",
    "build": "npm run build:content && npm run build:background",
    "package": "npm run build && node ./scripts/package-extension.js",
    "version": "node ./scripts/sync-version.js && git add manifest.json"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "adm-zip": "^0.5.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.5"
  }
}
